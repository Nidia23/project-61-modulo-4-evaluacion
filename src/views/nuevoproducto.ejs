<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Añadir Producto</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav>
        <a href="/">⬅ Volver al Catálogo</a> 
    </nav>

    <h1>Dar de alta un nuevo libro/producto</h1>

    <form action="/productos/nuevo" method="POST">
        <div>
            <label>Nombre del producto:</label>
            <input type="text" name="nombre" required placeholder="Ej: El Quijote">
        </div>

        <div>
            <label>Precio (€):</label>
            <input type="number" name="precio" step="0.01" required placeholder="19.99">
        </div>

        <div>
            <label>Categoría:</label>
            <input type="text" name="description" required placeholder="Ej: Novela">
        </div>

        <div>
            <label>Stock inicial:</label>
            <input type="number" name="stock" required value="10">
        </div>

        <button type="submit">Guardar Producto</button>
    </form>
</body>
</html>